# .env.example — copy to .env and fill in real values (never commit .env)

# Required: long random string (use: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string

# Required: comma-separated user:bcrypt-hash pairs
# Generate a hash with: make hash PASS=yourpassword
# Example (admin / password):
USERS=admin:$2a$12$changeme.replace.with.real.hash.here

# Optional
LISTEN_ADDR=:8080
SHELL=/bin/bash
SESSION_DURATION=8h

# Set to "true" when the app is behind HTTPS (nginx with TLS)
COOKIE_SECURE=false
